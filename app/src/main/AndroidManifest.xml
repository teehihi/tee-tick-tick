<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK" />
    <uses-permission android:name="android.permission.READ_CONTACTS" />

    <!-- Calendar: đọc và ghi sự kiện vào lịch Android -->
    <uses-permission android:name="android.permission.READ_CALENDAR" />
    <uses-permission android:name="android.permission.WRITE_CALENDAR" />

    <!-- Music Player: đọc nhạc từ thiết bị -->
    <uses-permission android:name="android.permission.READ_MEDIA_AUDIO" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />

    <!-- Custom permissions cho Content Provider - cho phép app khác đọc/ghi tasks -->
    <permission
        android:name="hcmute.edu.vn.teeticktick.READ_TASKS"
        android:label="Read TeeTickTick Tasks"
        android:protectionLevel="normal" />
    <permission
        android:name="hcmute.edu.vn.teeticktick.WRITE_TASKS"
        android:label="Write TeeTickTick Tasks"
        android:protectionLevel="normal" />

    <application
        android:name=".TeeTickTickApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.TeeTickTick">
        <activity
            android:name=".SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.TeeTickTick">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".OnboardingActivity"
            android:exported="false"
            android:theme="@style/Theme.TeeTickTick" />

        <activity
            android:name=".MainActivity"
            android:exported="false"
            android:theme="@style/Theme.TeeTickTick" />
        
        <activity
            android:name=".SmartListSettingsActivity"
            android:exported="false"
            android:theme="@style/Theme.TeeTickTick" />
        
        <activity
            android:name=".DebugCategoryActivity"
            android:exported="true"
            android:theme="@style/Theme.TeeTickTick" />

        <service
            android:name=".service.DailyTaskService"
            android:exported="false"
            android:foregroundServiceType="specialUse" />

        <!-- Music Bound Service -->
        <service
            android:name=".service.MusicService"
            android:exported="false"
            android:foregroundServiceType="mediaPlayback" />

        <!-- BroadcastReceiver điều khiển nhạc từ notification -->
        <receiver
            android:name=".receiver.MusicPlayerReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="hcmute.edu.vn.teeticktick.ACTION_PLAY_PAUSE" />
                <action android:name="hcmute.edu.vn.teeticktick.ACTION_NEXT" />
                <action android:name="hcmute.edu.vn.teeticktick.ACTION_PREVIOUS" />
                <action android:name="hcmute.edu.vn.teeticktick.ACTION_CLOSE" />
            </intent-filter>
        </receiver>

        <!-- Content Provider cho phép app khác truy cập tasks -->
        <provider
            android:name=".provider.TaskContentProvider"
            android:authorities="hcmute.edu.vn.teeticktick.provider"
            android:exported="true"
            android:readPermission="hcmute.edu.vn.teeticktick.READ_TASKS"
            android:writePermission="hcmute.edu.vn.teeticktick.WRITE_TASKS" />

    </application>

</manifest>