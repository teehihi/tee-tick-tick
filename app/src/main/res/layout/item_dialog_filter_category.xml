<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingVertical="12dp"
    android:background="?attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true">

    <View
        android:id="@+id/item_category_dot"
        android:layout_width="12dp"
        android:layout_height="12dp"
        android:background="@drawable/bg_category_dot"
        android:layout_marginEnd="12dp" />

    <TextView
        android:id="@+id/item_category_name"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:textColor="#1C1C1E"
        android:textSize="16sp" />

    <Switch
        android:id="@+id/item_category_toggle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:checked="true"
        android:thumb="@drawable/toggle_thumb"
        android:track="@drawable/toggle_track"
        android:clickable="false"
        android:focusable="false" />
</LinearLayout>
