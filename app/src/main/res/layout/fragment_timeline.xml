<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F2F2F7"
    tools:context=".TimelineFragment">

    <!-- iOS-style Control Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#FFFFFF"
        android:paddingStart="4dp"
        android:paddingEnd="4dp"
        android:elevation="2dp">

        <!-- Prev week: iOS chevron -->
        <TextView
            android:id="@+id/btn_prev_week"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:gravity="center"
            android:text="‹"
            android:textSize="24sp"
            android:textColor="#007AFF"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:includeFontPadding="false"
            android:clickable="true"
            android:focusable="true" />

        <!-- Zoom out -->
        <TextView
            android:id="@+id/btn_zoom_out"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:gravity="center"
            android:text="🔍−"
            android:textSize="11sp"
            android:textColor="#007AFF"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:includeFontPadding="false"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginStart="2dp" />

        <!-- Week label -->
        <TextView
            android:id="@+id/tv_week_label"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:textColor="#1C1C1E"
            android:textSize="15sp"
            android:textStyle="bold"
            android:letterSpacing="-0.02"
            android:text="Mar 10 – Mar 16"
            android:paddingStart="4dp"
            android:paddingEnd="4dp" />

        <!-- Zoom in -->
        <TextView
            android:id="@+id/btn_zoom_in"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:gravity="center"
            android:text="🔍+"
            android:textSize="11sp"
            android:textColor="#007AFF"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:includeFontPadding="false"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginEnd="2dp" />

        <!-- Next week: iOS chevron -->
        <TextView
            android:id="@+id/btn_next_week"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:gravity="center"
            android:text="›"
            android:textSize="24sp"
            android:textColor="#007AFF"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:includeFontPadding="false"
            android:clickable="true"
            android:focusable="true" />

    </LinearLayout>

    <!-- iOS separator line -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:background="#C6C6C8" />

    <!-- Gantt Grid Container -->
    <LinearLayout
        android:id="@+id/gantt_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal">

        <!-- Left Sidebar: Category Labels (iOS card look) -->
        <LinearLayout
            android:id="@+id/sidebar_labels"
            android:layout_width="88dp"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:elevation="2dp">

            <!-- Spacer matching date header height -->
            <View
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="#FFFFFF" />

            <View
                android:layout_width="match_parent"
                android:layout_height="0.5dp"
                android:background="#C6C6C8" />

            <!-- Row 1: Inbox -->
            <LinearLayout
                android:id="@+id/sidebar_row_1"
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:gravity="center_vertical"
                android:paddingStart="12dp"
                android:paddingEnd="6dp"
                android:orientation="horizontal">

                <View
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:background="@drawable/bg_category_dot"
                    android:backgroundTint="#5AC8FA"
                    android:layout_marginEnd="9dp" />

                <TextView
                    android:id="@+id/label_row_1"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Hộp thư"
                    android:textColor="#1C1C1E"
                    android:textSize="11sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="#E5E5EA" android:layout_marginStart="10dp" />

            <!-- Row 2: Work -->
            <LinearLayout
                android:id="@+id/sidebar_row_2"
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:gravity="center_vertical"
                android:paddingStart="12dp"
                android:paddingEnd="6dp"
                android:orientation="horizontal">

                <View
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:background="@drawable/bg_category_dot"
                    android:backgroundTint="#BF5AF2"
                    android:layout_marginEnd="9dp" />

                <TextView
                    android:id="@+id/label_row_2"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Công việc"
                    android:textColor="#1C1C1E"
                    android:textSize="11sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="#E5E5EA" android:layout_marginStart="10dp" />

            <!-- Row 3: Personal -->
            <LinearLayout
                android:id="@+id/sidebar_row_3"
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:gravity="center_vertical"
                android:paddingStart="12dp"
                android:paddingEnd="6dp"
                android:orientation="horizontal">

                <View
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:background="@drawable/bg_category_dot"
                    android:backgroundTint="#34C759"
                    android:layout_marginEnd="9dp" />

                <TextView
                    android:id="@+id/label_row_3"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Cá nhân"
                    android:textColor="#1C1C1E"
                    android:textSize="11sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="#E5E5EA" android:layout_marginStart="10dp" />

            <!-- Row 4: Shopping -->
            <LinearLayout
                android:id="@+id/sidebar_row_4"
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:gravity="center_vertical"
                android:paddingStart="12dp"
                android:paddingEnd="6dp"
                android:orientation="horizontal">

                <View
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:background="@drawable/bg_category_dot"
                    android:backgroundTint="#FF9500"
                    android:layout_marginEnd="9dp" />

                <TextView
                    android:id="@+id/label_row_4"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Mua sắm"
                    android:textColor="#1C1C1E"
                    android:textSize="11sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="#E5E5EA" android:layout_marginStart="10dp" />

            <!-- Row 5: Learning -->
            <LinearLayout
                android:id="@+id/sidebar_row_5"
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:gravity="center_vertical"
                android:paddingStart="12dp"
                android:paddingEnd="6dp"
                android:orientation="horizontal">

                <View
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:background="@drawable/bg_category_dot"
                    android:backgroundTint="#FF3B30"
                    android:layout_marginEnd="9dp" />

                <TextView
                    android:id="@+id/label_row_5"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Học tập"
                    android:textColor="#1C1C1E"
                    android:textSize="11sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="#C6C6C8" />

        </LinearLayout>

        <!-- Thin shadow separator -->
        <View
            android:layout_width="0.5dp"
            android:layout_height="match_parent"
            android:background="#C6C6C8" />

        <!-- Right Scrollable Grid -->
        <HorizontalScrollView
            android:id="@+id/gantt_horizontal_scroll"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:scrollbars="none"
            android:overScrollMode="never">

            <LinearLayout
                android:id="@+id/gantt_grid"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:background="#FFFFFF">

                <!-- Date Header Row -->
                <LinearLayout
                    android:id="@+id/date_header_row"
                    android:layout_width="wrap_content"
                    android:layout_height="52dp"
                    android:orientation="horizontal"
                    android:background="#FFFFFF" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="0.5dp"
                    android:background="#C6C6C8" />

                <!-- Row 1: Inbox -->
                <FrameLayout
                    android:id="@+id/row_inbox"
                    android:layout_width="wrap_content"
                    android:layout_height="72dp"
                    android:background="#FAFAFA" />

                <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="#E5E5EA" />

                <!-- Row 2: Work -->
                <FrameLayout
                    android:id="@+id/row_work"
                    android:layout_width="wrap_content"
                    android:layout_height="72dp"
                    android:background="#FFFFFF" />

                <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="#E5E5EA" />

                <!-- Row 3: Personal -->
                <FrameLayout
                    android:id="@+id/row_personal"
                    android:layout_width="wrap_content"
                    android:layout_height="72dp"
                    android:background="#FAFAFA" />

                <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="#E5E5EA" />

                <!-- Row 4: Shopping -->
                <FrameLayout
                    android:id="@+id/row_shopping"
                    android:layout_width="wrap_content"
                    android:layout_height="72dp"
                    android:background="#FFFFFF" />

                <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="#E5E5EA" />

                <!-- Row 5: Learning -->
                <FrameLayout
                    android:id="@+id/row_learning"
                    android:layout_width="wrap_content"
                    android:layout_height="72dp"
                    android:background="#FAFAFA" />

                <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="#C6C6C8" />

            </LinearLayout>
        </HorizontalScrollView>
    </LinearLayout>

    <!-- Empty state -->
    <LinearLayout
        android:id="@+id/timeline_empty_state"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="0"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="40dp"
        android:background="#F2F2F7"
        android:visibility="gone">

        <TextView
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:text="📅"
            android:textSize="52sp"
            android:gravity="center"
            android:layout_marginBottom="20dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Chưa có nhiệm vụ"
            android:textColor="#1C1C1E"
            android:textSize="17sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Thêm nhiệm vụ với ngày hạn để hiển thị trên lịch này"
            android:textColor="#8E8E93"
            android:textSize="14sp"
            android:gravity="center" />
    </LinearLayout>

</LinearLayout>
