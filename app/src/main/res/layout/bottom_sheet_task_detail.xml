<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bottom_sheet_background"
    android:fillViewport="true">

<LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="20dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Chi tiết nhiệm vụ"
            android:textColor="@color/text_primary"
            android:textSize="18sp"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/close_button"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@drawable/ic_ios_x_circle"
            android:contentDescription="Đóng"
            android:clickable="true"
            android:focusable="true" />
    </LinearLayout>

    <!-- Task Title with Emoji -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@drawable/bg_input_field"
        android:padding="14dp"
        android:gravity="center_vertical"
        android:layout_marginBottom="20dp">

        <TextView
            android:id="@+id/emoji_selector"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:gravity="center"
            android:text="✅"
            android:textSize="26sp"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:layout_marginEnd="10dp" />

        <EditText
            android:id="@+id/task_title_input"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:hint="Tiêu đề nhiệm vụ"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_secondary"
            android:textSize="16sp"
            android:padding="4dp"
            android:maxLines="3" />
    </LinearLayout>

    <!-- Priority Section -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Độ ưu tiên"
        android:textColor="@color/text_primary"
        android:textSize="14sp"
        android:textStyle="bold"
        android:layout_marginBottom="10dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="20dp">

        <TextView
            android:id="@+id/priority_low"
            android:layout_width="0dp"
            android:layout_height="46dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:background="@drawable/chip_priority_selector"
            android:gravity="center"
            android:text="Thấp"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/priority_medium"
            android:layout_width="0dp"
            android:layout_height="46dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:background="@drawable/chip_priority_selector"
            android:gravity="center"
            android:text="Trung bình"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/priority_high"
            android:layout_width="0dp"
            android:layout_height="46dp"
            android:layout_weight="1"
            android:background="@drawable/chip_priority_selector"
            android:gravity="center"
            android:text="Cao"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:clickable="true"
            android:focusable="true" />
    </LinearLayout>

    <!-- Due Date Section -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Hạn chót"
        android:textColor="@color/text_primary"
        android:textSize="14sp"
        android:textStyle="bold"
        android:layout_marginBottom="10dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="20dp">

        <TextView
            android:id="@+id/date_today"
            android:layout_width="0dp"
            android:layout_height="46dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:background="@drawable/chip_category_selector"
            android:gravity="center"
            android:text="Hôm nay"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/date_tomorrow"
            android:layout_width="0dp"
            android:layout_height="46dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:background="@drawable/chip_category_selector"
            android:gravity="center"
            android:text="Ngày mai"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/date_this_week"
            android:layout_width="0dp"
            android:layout_height="46dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:background="@drawable/chip_category_selector"
            android:gravity="center"
            android:text="Tuần này"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/date_pick"
            android:layout_width="0dp"
            android:layout_height="46dp"
            android:layout_weight="1"
            android:background="@drawable/chip_category_selector"
            android:gravity="center"
            android:text="Chọn"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:clickable="true"
            android:focusable="true" />
    </LinearLayout>

    <!-- Category Section -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Danh sách"
        android:textColor="@color/text_primary"
        android:textSize="14sp"
        android:textStyle="bold"
        android:layout_marginBottom="10dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="24dp">

        <TextView
            android:id="@+id/category_personal"
            android:layout_width="0dp"
            android:layout_height="46dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:background="@drawable/chip_category_selector"
            android:gravity="center"
            android:text="Cá nhân"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/category_work"
            android:layout_width="0dp"
            android:layout_height="46dp"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:background="@drawable/chip_category_selector"
            android:gravity="center"
            android:text="Công việc"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:clickable="true"
            android:focusable="true" />

        <TextView
            android:id="@+id/category_shopping"
            android:layout_width="0dp"
            android:layout_height="46dp"
            android:layout_weight="1"
            android:background="@drawable/chip_category_selector"
            android:gravity="center"
            android:text="Mua sắm"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:clickable="true"
            android:focusable="true" />
    </LinearLayout>

    <!-- Action Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="8dp">

        <Button
            android:id="@+id/delete_task_button"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:layout_marginEnd="10dp"
            android:background="@drawable/bg_input_field"
            android:text="Xóa"
            android:textColor="#E53935"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textAllCaps="false"
            android:elevation="0dp"
            android:stateListAnimator="@null" />

        <Button
            android:id="@+id/update_task_button"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:background="@drawable/bg_button_update"
            android:text="Cập nhật"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textAllCaps="false"
            android:elevation="2dp"
            android:stateListAnimator="@null" />
    </LinearLayout>

</LinearLayout>
</ScrollView>
