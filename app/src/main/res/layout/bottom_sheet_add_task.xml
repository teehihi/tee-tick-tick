<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_rounded_white"
    android:paddingStart="24dp"
    android:paddingEnd="24dp"
    android:paddingTop="16dp"
    android:paddingBottom="24dp">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="20dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Nhiệm vụ mới"
            android:textColor="@color/text_primary"
            android:textSize="22sp"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/close_button"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:padding="6dp"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            app:tint="@color/text_secondary"
            android:background="?attr/selectableItemBackgroundBorderless" />
    </LinearLayout>

    <!-- Emoji + Task Input Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="24dp">

        <!-- Emoji Selector Button -->
        <com.vanniktech.emoji.EmojiTextView
            android:id="@+id/emoji_selector"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:text="✅"
            android:textSize="28sp"
            android:gravity="center"
            android:background="@drawable/bg_input_field"
            android:layout_marginEnd="12dp"
            android:clickable="true"
            android:focusable="true" />

        <!-- Task Input layout containing Title and Description -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="@drawable/bg_input_field">

            <EditText
                android:id="@+id/task_title_input"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@null"
                android:hint="Bạn cần làm gì?"
                android:textColorHint="@color/text_secondary"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:inputType="textCapSentences" />

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:background="#E0E0E0" />

            <EditText
                android:id="@+id/task_description_input"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="56dp"
                android:background="@null"
                android:hint="Thêm mô tả chi tiết..."
                android:textColorHint="@color/text_secondary"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:padding="16dp"
                android:inputType="textMultiLine|textCapSentences"
                android:gravity="top|start" />
        </LinearLayout>
    </LinearLayout>

    <!-- Priority Section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@android:drawable/btn_star"
                app:tint="@color/text_secondary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="Độ ưu tiên"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <TextView
                android:id="@+id/priority_low"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:text="Thấp"
                android:textColor="@color/text_secondary"
                android:textSize="15sp"
                android:gravity="center"
                android:background="@drawable/chip_priority_selector"
                android:layout_marginEnd="8dp"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/priority_medium"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:text="Trung bình"
                android:textColor="@color/white"
                android:textSize="15sp"
                android:textStyle="bold"
                android:gravity="center"
                android:background="@drawable/chip_priority_selector"
                android:layout_marginEnd="8dp"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/priority_high"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:text="Cao"
                android:textColor="@color/text_secondary"
                android:textSize="15sp"
                android:gravity="center"
                android:background="@drawable/chip_priority_selector"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>
    </LinearLayout>

    <!-- Due Date Section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@android:drawable/ic_menu_my_calendar"
                app:tint="@color/text_secondary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="Ngày đến hạn"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:textStyle="bold" />
        </LinearLayout>

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/date_today"
                    android:layout_width="wrap_content"
                    android:layout_height="44dp"
                    android:minWidth="100dp"
                    android:text="Hôm nay"
                    android:textColor="@color/text_secondary"
                    android:textSize="15sp"
                    android:gravity="center"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp"
                    android:background="@drawable/chip_category_selector"
                    android:layout_marginEnd="8dp"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/date_tomorrow"
                    android:layout_width="wrap_content"
                    android:layout_height="44dp"
                    android:minWidth="100dp"
                    android:text="Ngày mai"
                    android:textColor="@color/text_secondary"
                    android:textSize="15sp"
                    android:gravity="center"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp"
                    android:background="@drawable/chip_category_selector"
                    android:layout_marginEnd="8dp"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/date_this_week"
                    android:layout_width="wrap_content"
                    android:layout_height="44dp"
                    android:minWidth="100dp"
                    android:text="Tuần này"
                    android:textColor="@color/text_secondary"
                    android:textSize="15sp"
                    android:gravity="center"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp"
                    android:background="@drawable/chip_category_selector"
                    android:layout_marginEnd="8dp"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/date_pick"
                    android:layout_width="wrap_content"
                    android:layout_height="44dp"
                    android:minWidth="100dp"
                    android:text="Chọn ngày"
                    android:textColor="@color/text_secondary"
                    android:textSize="15sp"
                    android:gravity="center"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp"
                    android:background="@drawable/chip_category_selector"
                    android:layout_marginEnd="8dp"
                    android:clickable="true"
                    android:focusable="true" />

                <!-- Time Picker -->
                <TextView
                    android:id="@+id/time_pick"
                    android:layout_width="wrap_content"
                    android:layout_height="44dp"
                    android:minWidth="80dp"
                    android:text="23:59"
                    android:textColor="@color/text_secondary"
                    android:textSize="15sp"
                    android:gravity="center"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:background="@drawable/chip_category_selector"
                    android:layout_marginEnd="8dp"
                    android:clickable="true"
                    android:focusable="true" />
            </LinearLayout>
        </HorizontalScrollView>
    </LinearLayout>

    <!-- Category Section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@android:drawable/ic_menu_agenda"
                app:tint="@color/text_secondary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="Danh mục"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:id="@+id/select_category_button"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:text="Chọn danh mục"
            android:textColor="@color/text_primary"
            android:textSize="15sp"
            android:textStyle="bold"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:background="@drawable/chip_category_selector"
            android:drawableEnd="@android:drawable/arrow_down_float"
            android:clickable="true"
            android:focusable="true" />
    </LinearLayout>

    <!-- Add Task Button -->
    <Button
        android:id="@+id/add_task_button"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Thêm nhiệm vụ"
        android:textColor="@color/white"
        android:textSize="16sp"
        android:textStyle="bold"
        android:background="@drawable/bg_button_green"
        app:backgroundTint="@null"
        android:elevation="0dp"
        android:stateListAnimator="@null" />

</LinearLayout>
