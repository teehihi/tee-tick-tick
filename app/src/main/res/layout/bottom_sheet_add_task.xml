<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_bottom_sheet_28">

    <!-- Drag handle -->
    <View
        android:layout_width="40dp"
        android:layout_height="6dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_drag_handle" />

    <!-- Header: Hủy | Task mới | Thêm -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp">

        <TextView
            android:id="@+id/btn_cancel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Hủy"
            android:textSize="16sp"
            android:textColor="#2B7FFF"
            android:fontFamily="sans-serif-medium"
            android:padding="4dp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Task mới"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#0A0A0A"
            android:gravity="center" />

        <TextView
            android:id="@+id/btn_add_header"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Thêm"
            android:textSize="16sp"
            android:textColor="#2B7FFF"
            android:fontFamily="sans-serif-medium"
            android:padding="4dp" />
    </LinearLayout>

    <!-- Scrollable content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingBottom="24dp">

            <!-- Icon + Task Input Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="top"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="16dp">

                <!-- Icon/Emoji Selector: 56x56, blue bg, radius 16 -->
                <ImageView
                    android:id="@+id/emoji_selector"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:src="@drawable/ic_ios_check_circle"
                    android:scaleType="center"
                    android:padding="14dp"
                    android:background="@drawable/bg_icon_blue"
                    android:layout_marginEnd="12dp"
                    android:clickable="true"
                    android:focusable="true"
                    app:tint="#FFFFFF" />

                <!-- Title + Description, no background -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center_vertical">

                    <EditText
                        android:id="@+id/task_title_input"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:minHeight="32dp"
                        android:background="@null"
                        android:hint="Tên task"
                        android:textColorHint="#99A1AF"
                        android:textColor="#0A0A0A"
                        android:textSize="18sp"
                        android:fontFamily="sans-serif-medium"
                        android:inputType="textCapSentences"
                        android:paddingTop="0dp"
                        android:paddingBottom="4dp" />

                    <EditText
                        android:id="@+id/task_description_input"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:minHeight="24dp"
                        android:background="@null"
                        android:hint="Mô tả task"
                        android:textColorHint="#99A1AF"
                        android:textColor="#4A5565"
                        android:textSize="14sp"
                        android:inputType="textMultiLine|textCapSentences"
                        android:gravity="top|start"
                        android:paddingTop="0dp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Tab: Ngày / Thời lượng -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:orientation="horizontal"
                android:background="@drawable/bg_tab_container"
                android:layout_marginBottom="12dp"
                android:padding="4dp">

                <TextView
                    android:id="@+id/tab_date"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="Ngày"
                    android:textSize="15sp"
                    android:fontFamily="sans-serif-medium"
                    android:gravity="center"
                    android:background="@drawable/bg_tab_selected_shadow"
                    android:textColor="#000000"
                    android:clickable="true"
                    android:focusable="true" />

                <TextView
                    android:id="@+id/tab_duration"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="Thời lượng"
                    android:textSize="15sp"
                    android:gravity="center"
                    android:background="@android:color/transparent"
                    android:textColor="#4A5565"
                    android:clickable="true"
                    android:focusable="true" />
            </LinearLayout>

            <!-- DATE panel -->
            <LinearLayout
                android:id="@+id/panel_date"
                android:layout_width="match_parent"
                android:layout_height="76dp"
                android:orientation="horizontal"
                android:background="@drawable/bg_date_row"
                android:layout_marginBottom="8dp"
                android:padding="16dp"
                android:gravity="center_vertical"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground">

                <!-- Calendar icon box: blue -->
                <LinearLayout
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:gravity="center"
                    android:background="@drawable/bg_icon_box_blue"
                    android:layout_marginEnd="12dp">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_ios_calendar"
                        app:tint="#FFFFFF" />
                </LinearLayout>

                <!-- Date info -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ngày"
                        android:textSize="13sp"
                        android:textColor="#6A7282"
                        android:fontFamily="sans-serif-medium"
                        android:layout_marginBottom="2dp" />

                    <TextView
                        android:id="@+id/start_date_btn"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Chọn ngày"
                        android:textSize="16sp"
                        android:textColor="#0A0A0A"
                        android:fontFamily="sans-serif-medium"
                        android:clickable="false"
                        android:focusable="false" />
                </LinearLayout>

                <!-- Time button with clock icon -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_ios_clock"
                        android:layout_marginEnd="4dp"
                        app:tint="#2B7FFF" />

                    <TextView
                        android:id="@+id/start_time_btn"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--:--"
                        android:textSize="15sp"
                        android:textColor="#2B7FFF"
                        android:fontFamily="sans-serif-medium"
                        android:clickable="false"
                        android:focusable="false" />
                </LinearLayout>
            </LinearLayout>

            <!-- DURATION panel (hidden by default) -->
            <LinearLayout
                android:id="@+id/panel_duration"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="8dp"
                android:visibility="gone">

                <!-- Start row -->
                <LinearLayout
                    android:id="@+id/row_dur_start"
                    android:layout_width="match_parent"
                    android:layout_height="72dp"
                    android:orientation="horizontal"
                    android:background="@drawable/bg_date_row"
                    android:layout_marginBottom="8dp"
                    android:padding="16dp"
                    android:gravity="center_vertical"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">

                    <LinearLayout
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:gravity="center"
                        android:background="@drawable/bg_icon_box_blue"
                        android:layout_marginEnd="12dp">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_ios_calendar"
                            app:tint="#FFFFFF" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Ngày bắt đầu"
                            android:textSize="13sp"
                            android:textColor="#6A7282"
                            android:layout_marginBottom="2dp" />

                        <TextView
                            android:id="@+id/dur_start_date_btn"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Chọn ngày"
                            android:textSize="16sp"
                            android:textColor="#0A0A0A"
                            android:fontFamily="sans-serif-medium"
                            android:clickable="true"
                            android:focusable="true" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:clickable="true"
                        android:focusable="true">

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_ios_clock"
                            android:layout_marginEnd="4dp"
                            app:tint="#2B7FFF" />

                        <TextView
                            android:id="@+id/dur_start_time_btn"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="--:--"
                            android:textSize="15sp"
                            android:textColor="#2B7FFF"
                            android:fontFamily="sans-serif-medium"
                            android:clickable="false"
                            android:focusable="false" />
                    </LinearLayout>
                </LinearLayout>

                <!-- End row -->
                <LinearLayout
                    android:id="@+id/row_dur_end"
                    android:layout_width="match_parent"
                    android:layout_height="72dp"
                    android:orientation="horizontal"
                    android:background="@drawable/bg_date_row"
                    android:layout_marginBottom="8dp"
                    android:padding="16dp"
                    android:gravity="center_vertical"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground">

                    <LinearLayout
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:gravity="center"
                        android:background="@drawable/bg_icon_box_blue"
                        android:layout_marginEnd="12dp">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_ios_calendar"
                            app:tint="#FFFFFF" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Ngày kết thúc"
                            android:textSize="13sp"
                            android:textColor="#6A7282"
                            android:layout_marginBottom="2dp" />

                        <TextView
                            android:id="@+id/dur_end_date_btn"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Chọn ngày"
                            android:textSize="16sp"
                            android:textColor="#0A0A0A"
                            android:fontFamily="sans-serif-medium"
                            android:clickable="true"
                            android:focusable="true" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:clickable="true"
                        android:focusable="true">

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_ios_clock"
                            android:layout_marginEnd="4dp"
                            app:tint="#2B7FFF" />

                        <TextView
                            android:id="@+id/dur_end_time_btn"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="--:--"
                            android:textSize="15sp"
                            android:textColor="#2B7FFF"
                            android:fontFamily="sans-serif-medium"
                            android:clickable="false"
                            android:focusable="false" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Duration label chip -->
                <TextView
                    android:id="@+id/tv_duration_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Thời lượng: 1 ngày"
                    android:textSize="13sp"
                    android:textColor="#2B7FFF"
                    android:background="@drawable/bg_duration_chip"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="6dp"
                    android:paddingBottom="6dp"
                    android:layout_marginBottom="8dp"
                    android:visibility="gone" />
            </LinearLayout>

            <!-- "Thông tin thêm" row: orange icon -->
            <LinearLayout
                android:id="@+id/row_extra_info"
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:orientation="horizontal"
                android:background="@drawable/bg_date_row"
                android:layout_marginBottom="8dp"
                android:padding="16dp"
                android:gravity="center_vertical"
                android:clickable="true"
                android:focusable="true">

                <!-- Orange icon box -->
                <LinearLayout
                    android:id="@+id/extra_info_icon_box"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:gravity="center"
                    android:background="@drawable/bg_icon_box_orange"
                    android:layout_marginEnd="12dp">

                    <ImageView
                        android:id="@+id/extra_info_icon"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_ios_info"
                        app:tint="#FFFFFF" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Thông tin thêm"
                        android:textSize="13sp"
                        android:textColor="#6A7282"
                        android:fontFamily="sans-serif-medium"
                        android:layout_marginBottom="2dp" />

                    <TextView
                        android:id="@+id/tv_extra_info"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Chưa thiết lập"
                        android:textSize="14sp"
                        android:textColor="#0A0A0A"
                        android:fontFamily="sans-serif-medium" />
                </LinearLayout>
            </LinearLayout>

            <!-- Assignee chips (shown after picking contact) -->
            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chip_group_assignees"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                app:chipSpacingVertical="4dp"
                app:chipSpacingHorizontal="4dp" />

        </LinearLayout>
    </ScrollView>

</LinearLayout>
