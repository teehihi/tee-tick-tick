<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_dialog_rounded"
    android:orientation="vertical">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Header -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerHorizontal="true"
                    android:gravity="center"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Thêm danh mục mới"
                        android:textColor="#0A0A0A"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Tạo danh mục mới cho giao dịch của bạn"
                        android:textColor="#9CA3AF"
                        android:textSize="12sp" />
                </LinearLayout>

                <ImageView
                    android:id="@+id/btn_close"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:padding="2dp"
                    android:src="@drawable/ic_ios_x_circle"
                    app:tint="#9CA3AF" />
            </RelativeLayout>

            <!-- Tên danh mục -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Tên danh mục *"
                android:textColor="#374151"
                android:textSize="13sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/et_category_name"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_input_gray"
                android:hint="Nhập tên danh mục"
                android:paddingHorizontal="16dp"
                android:textColor="#111827"
                android:textColorHint="#9CA3AF"
                android:textSize="14sp" />

            <!-- Chọn biểu tượng -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="Chọn biểu tượng *"
                android:textColor="#374151"
                android:textSize="13sp"
                android:textStyle="bold" />

            <!-- Using a Grid layout to hold dynamically populated icons -->
            <GridLayout
                android:id="@+id/grid_icons"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_preview_box"
                android:padding="8dp"
                android:columnCount="6"
                android:rowCount="4" />

            <!-- Chọn màu sắc -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="Chọn màu sắc *"
                android:textColor="#374151"
                android:textSize="13sp"
                android:textStyle="bold" />

            <GridLayout
                android:id="@+id/grid_colors"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_preview_box"
                android:padding="8dp"
                android:columnCount="9"
                android:rowCount="2" />

            <!-- Xem trước -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="Xem trước"
                android:textColor="#374151"
                android:textSize="13sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_preview_box"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="20dp">

                <ImageView
                    android:id="@+id/iv_preview_icon"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:src="@drawable/ic_tc_icon_10"
                    app:tint="#10B981" />

                <TextView
                    android:id="@+id/tv_preview_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Tên danh mục"
                    android:textColor="#111827"
                    android:textSize="14sp" />
            </LinearLayout>

            <!-- Buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/btn_cancel"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_button_white_border"
                    android:gravity="center"
                    android:text="Hủy"
                    android:textColor="#374151"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <View
                    android:layout_width="12dp"
                    android:layout_height="match_parent" />

                <TextView
                    android:id="@+id/btn_add"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_button_black"
                    android:gravity="center"
                    android:text="Thêm mới"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold" />

            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>
