<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_now_playing"
    android:fitsSystemWindows="true"
    android:paddingStart="28dp"
    android:paddingEnd="28dp">

    <!-- Top bar: chevron down + title + more -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="16dp">

        <ImageButton
            android:id="@+id/btn_dismiss"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_centerVertical="true"
            android:layout_alignParentStart="true"
            android:background="@null"
            android:src="@drawable/ic_chevron_down"
            android:contentDescription="Đóng"
            android:tint="#FFFFFF" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Đang phát từ danh sách"
                android:textSize="12sp"
                android:textColor="#CCFFFFFF" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tất cả bài hát"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF" />

        </LinearLayout>

        <ImageButton
            android:id="@+id/btn_more"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_centerVertical="true"
            android:layout_alignParentEnd="true"
            android:background="@null"
            android:src="@drawable/ic_ios_ellipsis_vertical"
            android:contentDescription="Thêm"
            android:tint="#FFFFFF" />

    </RelativeLayout>

    <!-- Album Art -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="32dp"
        android:layout_marginBottom="32dp">

        <FrameLayout
            android:id="@+id/album_art_container"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:layout_constraintDimensionRatio="1:1"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:background="@drawable/bg_album_art"
            android:elevation="16dp">

            <ImageView
                android:id="@+id/album_art_icon"
                android:layout_width="96dp"
                android:layout_height="96dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_music"
                android:contentDescription="Album art"
                app:tint="#FFFFFF" />

        </FrameLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Song title (marquee) + heart -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="4dp">

        <TextView
            android:id="@+id/now_playing_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_toStartOf="@+id/btn_like"
            android:layout_marginEnd="12dp"
            android:text="Tên bài hát"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:singleLine="true"
            android:ellipsize="marquee"
            android:marqueeRepeatLimit="marquee_forever"
            android:focusable="true" />

        <ImageButton
            android:id="@+id/btn_like"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:background="@null"
            android:src="@drawable/ic_heart_outline"
            android:contentDescription="Yêu thích"
            android:tint="#FFFFFF" />

    </RelativeLayout>

    <TextView
        android:id="@+id/now_playing_artist"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Nghệ sĩ"
        android:textSize="16sp"
        android:textColor="#CCFFFFFF"
        android:layout_marginBottom="20dp" />

    <!-- SeekBar -->
    <SeekBar
        android:id="@+id/now_playing_seekbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:progressDrawable="@drawable/bg_seekbar_track"
        android:thumb="@drawable/bg_seekbar_thumb"
        android:splitTrack="false"
        android:max="100"
        android:progress="0"
        android:paddingStart="0dp"
        android:paddingEnd="0dp" />

    <!-- Time labels -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="24dp">

        <TextView
            android:id="@+id/now_playing_current"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:text="0:00"
            android:textSize="12sp"
            android:textColor="#CCFFFFFF" />

        <TextView
            android:id="@+id/now_playing_duration"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:text="0:00"
            android:textSize="12sp"
            android:textColor="#CCFFFFFF" />

    </RelativeLayout>

    <!-- Controls: shuffle | prev | play | next | repeat -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="32dp"
        android:gravity="center_vertical">

        <ImageButton
            android:id="@+id/btn_shuffle"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:background="@null"
            android:src="@drawable/ic_shuffle"
            android:contentDescription="Shuffle"
            android:tint="#CCFFFFFF" />

        <ImageButton
            android:id="@+id/btn_previous"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_toStartOf="@+id/btn_play_pause_detail"
            android:layout_centerVertical="true"
            android:layout_marginEnd="16dp"
            android:background="@null"
            android:src="@drawable/ic_skip_previous_fill"
            android:contentDescription="Trước"
            android:tint="#FFFFFF" />

        <!-- Play button: white circle -->
        <FrameLayout
            android:id="@+id/btn_play_pause_detail"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:layout_centerInParent="true"
            android:background="@drawable/bg_play_circle"
            android:elevation="4dp">

            <ImageView
                android:id="@+id/ic_play_pause_detail"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_play_fill"
                android:contentDescription="Play/Pause" />

        </FrameLayout>

        <ImageButton
            android:id="@+id/btn_next_detail"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_toEndOf="@+id/btn_play_pause_detail"
            android:layout_centerVertical="true"
            android:layout_marginStart="16dp"
            android:background="@null"
            android:src="@drawable/ic_skip_next_fill"
            android:contentDescription="Tiếp"
            android:tint="#FFFFFF" />

        <ImageButton
            android:id="@+id/btn_repeat"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:background="@null"
            android:src="@drawable/ic_repeat"
            android:contentDescription="Lặp lại"
            android:tint="#CCFFFFFF" />

    </RelativeLayout>

</LinearLayout>
